{
  "name": "@introspection-recipes/customer-support",
  "version": "0.1.0",
  "description": "Customer support recipe that triages Slack threads, searches Notion, drafts replies, and escalates sensitive requests.",
  "type": "module",
  "license": "Apache-2.0",
  "pi": {
    "agents": [
      "agents/*.yaml"
    ],
    "skills": [
      "skills/**/SKILL.md"
    ],
    "mcp": {
      "servers": [
        {
          "id": "slack",
          "required": false,
          "tools": {
            "allow": [
              "slack_read_channel",
              "slack_read_thread",
              "slack_send_message_draft"
            ]
          }
        },
        {
          "id": "notion",
          "required": false,
          "tools": {
            "allow": [
              "API-post-search",
              "API-retrieve-page-markdown"
            ]
          }
        }
      ]
    }
  }
}
